D <- data.frame (
design = c("SL1", "SL2", "I alt"),
Kvinder = K,
Mænd = M,
IAlt = K+M
)
A = D$IAlt[1]
Ac = D$IAlt[2]
B = D$Kvinder[3]
Bc = D$Mænd[3]
cat("De endelige sandsynligheder bliver \n",
"P(A) =", A / sum(A, Ac),
"P(A^{c}) =", Ac / sum(A, Ac),
"P(B) =", B / sum(B, Bc),
"P(B^{c}) =", Bc / sum(B, Bc))
