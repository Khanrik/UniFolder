B = D$Kvinder[3]
Bc = D$Mænd[3]
PA = A / sum(A, Ac)
PAc = Ac / sum(A, Ac)
PB = B / sum(B, Bc)
PBc = Bc / sum(B, Bc)
cat("De endelige sandsynligheder bliver \n",
"P(A) =", PA,
"P(A^{c}) =", PAc,
"P(B) =", PB,
