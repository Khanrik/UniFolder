P_B_l_Mc = 0.13
U = 1075
M = 945
P_M = M / U
P_Mc = 1 - P_M
P_B_l_M = 1 - P_Bc_l_M
P_B = P_B_l_M * P_M + P_B_l_Mc * P_Mc
P_Bc_l_Mc = (P_B - P_B_l_M * P_M) / P_Mc
cat("De ønskede værdier er \nP(M) =", P_M, "\nP(Mc) =", P_Mc, "\nP(B | M) =", P_B_l_M, "\nP(Bc | Mc) =", P_Bc_l_Mc)
